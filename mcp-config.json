{
  "mcpServers": {
    "stitch": {
      "command": "npx",
      "args": ["-y", "@stitch-mcp/server"],
      "env": {}
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
      "env": {}
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "postgresql://ecommerce:ecommerce_password@db:5432/ecommerce"],
      "env": {}
    }
  }
}
